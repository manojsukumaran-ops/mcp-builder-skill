__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
dist/
build/
*.egg-info/
.eggs/

# Node
node_modules/
npm-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Local Claude Code settings (machine-specific permissions)
.claude/settings.local.json

# Logs
*.log
logs/
